# Choose provider: anthropic | openai | ollama | mock
# If unset or keys missing, the app falls back to the built-in rule-based "mock" extractor
# so you can demo without any API keys.
LLM_PROVIDER=anthropic

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI-compatible (OpenAI, gateways, etc.) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Local Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5
