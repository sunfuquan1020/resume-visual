# ============================================================================
#  Resume Visualizer — model configuration
#  用法：把本文件复制为 .env.local 后填写。   cp .env.example .env.local
#  .env.local 已被 .gitignore 排除，绝不会提交到 Git（密钥安全）。
#  改完需重启 dev server 才生效：  Ctrl+C 然后 npm run dev
# ============================================================================

# 选择一个供应商： anthropic | openai | openrouter | ollama | mock
#   - 留空或未配置对应 KEY 时，自动回退到内置规则解析 mock（无需联网/密钥，但质量有限）
#   - 上传解析、中英翻译、AI 助手对话都会用这里选定的供应商
LLM_PROVIDER=ollama

# --- 1) Anthropic Claude（云端，质量最高） -----------------------------------
#   申请 KEY: https://console.anthropic.com/  →  设 LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- 2) OpenAI 兼容（OpenAI 官方或任意兼容网关） -----------------------------
#   设 LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- 3) OpenRouter（一个 KEY 调用上百种模型，OpenAI 兼容） -------------------
#   申请 KEY: https://openrouter.ai/keys  →  设 LLM_PROVIDER=openrouter
#   MODEL 用 "厂商/模型" 格式，建议选支持 structured outputs 的模型，例如：
#     openai/gpt-4o-mini · anthropic/claude-3.5-sonnet · google/gemini-2.0-flash-001
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- 4) 本地 Ollama（完全离线、免费） ---------------------------------------
#   安装: https://ollama.com  →  ollama pull <model>  →  设 LLM_PROVIDER=ollama
#   HOST 容错：写成 0.0.0.0 或漏 http:// / 端口都会自动归一化
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5
